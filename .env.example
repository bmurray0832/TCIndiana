# Postgres connection (Railway, Supabase, or local docker)
DATABASE_URL="postgresql://user:password@localhost:5432/tcindiana?schema=public"

# Dev-only: which seeded user to act as while Auth0 isn't wired yet.
# Match a User.email row created by `npm run db:seed`.
DEV_USER_EMAIL="director@tcindiana.org"

# Phase 3 (online giving)
# When both are set, /give/[centerSlug] takes real donations through
# Stripe Checkout. Webhook lives at /api/stripe/webhook — register that
# URL in the Stripe dashboard for these events:
#   checkout.session.completed, invoice.payment_succeeded, charge.refunded
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Phase 4 (email send + log)
# Resend for outbound transactional + composer-driven emails. When
# both vars are set, the "Send email" composer actually sends; without
# them, the email still logs a Contact entry for record-keeping.
# RESEND_API_KEY=re_...
# RESEND_FROM_ADDRESS="TC Indiana <hello@tcindiana.org>"

# Phase 4.5 — per-user Outlook OAuth. When both are set, staff can
# connect their mailbox in Settings → Email integrations and emails
# sent from the CRM come from their own address with replies routing
# to their inbox. Register the app in Azure with redirect URI:
#   ${APP_BASE_URL}/api/auth/microsoft/callback
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=

# Phase 4.6 — Gmail equivalent. Same pattern, not yet wired up.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# Phase 5 — scheduled cron jobs. Set this and the railway.toml
# crons will pass the bearer header for auth. Without it (dev only),
# the endpoints are accessible without auth so you can hit them
# manually with curl during development.
# CRON_SECRET=...

# Auth0 (Phase 0.5)
# When all four AUTH0_* vars are set, the app uses Auth0. Otherwise it
# falls back to DEV_USER_EMAIL (dev only — production refuses).
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_SECRET=  # openssl rand -hex 32
# APP_BASE_URL=https://crm.tcindiana.org  # canonical origin for OIDC callbacks
