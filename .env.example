# Postgres connection (Railway, Supabase, or local docker)
DATABASE_URL="postgresql://user:password@localhost:5432/tcindiana?schema=public"

# Dev-only: which seeded user to act as while Auth0 isn't wired yet.
# Match a User.email row created by `npm run db:seed`.
DEV_USER_EMAIL="director@tcindiana.org"

# Phase 3 (online giving)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Phase 4 (email send + log)
# Resend for outbound transactional + composer-driven emails. When
# both vars are set, the "Send email" composer actually sends; without
# them, the email still logs a Contact entry for record-keeping.
# RESEND_API_KEY=re_...
# RESEND_FROM_ADDRESS="TC Indiana <hello@tcindiana.org>"

# Future (Phase 4.5): per-user OAuth so emails send from the staff
# member's own Outlook/Gmail mailbox, with replies routed naturally.
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# Auth0 (Phase 0.5)
# When all four AUTH0_* vars are set, the app uses Auth0. Otherwise it
# falls back to DEV_USER_EMAIL (dev only — production refuses).
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_SECRET=  # openssl rand -hex 32
# APP_BASE_URL=https://crm.tcindiana.org  # canonical origin for OIDC callbacks
